  const contact = {
    firstName:   "Charlotte",
    lastName:    "Skinner",
    jobTitle:    "Founder & Director",
    company:     "The Surrey Mortgage Company",
    mobile:      "+447741665205",
    email:       "charlotte@thesurreymc.co.uk",
    website:     "https://thesurreymortgagecompany.co.uk",
    linkedin:    "https://uk.linkedin.com/in/charlotte-skinner-11a64a37",
    photo: "image/jpeg;base64,",
  };
  // ─────────────────────────────────────────────

  const initials = (contact.firstName[0] || '') + (contact.lastName[0] || '');
  // Avatar uses photo — initials fallback disabled
  // document.getElementById('avatarEl').textContent = initials.toUpperCase();
  document.getElementById('fullName').textContent = `${contact.firstName} ${contact.lastName}`;

  const fmt = n => n.replace('+44','0').replace(/(\d{4,5})(\d+)/,'$1 $2');

  const mb = document.getElementById('mobileEl');
  mb.href = `tel:${contact.mobile}`; mb.textContent = fmt(contact.mobile);

  const em = document.getElementById('emailEl');
  em.href = `mailto:${contact.email}`; em.textContent = contact.email;

  const wb = document.getElementById('websiteEl');
  wb.href = contact.website; wb.textContent = contact.website.replace(/^https?:\/\//,'');

function foldLine(line) {
  const MAX = 75;
  if (line.length <= MAX) return line;
  let out = '';
  while (line.length > MAX) {
    out += line.slice(0, MAX) + '\r\n ';
    line = line.slice(MAX);
  }
  return out + line;
}

function buildVCard(c) {
  // Strip data URI prefix if present
  const photoData = c.photo
    ? c.photo.replace(/^image\/jpeg;base64,/, '').replace(/^data:[^;]+;base64,/, '')
    : null;

  const lines = [
    'BEGIN:VCARD', 'VERSION:3.0',
    `N:${c.lastName};${c.firstName};;;`,
    `FN:${c.firstName} ${c.lastName}`,
    c.jobTitle ? `TITLE:${c.jobTitle}` : '',
    c.company  ? `ORG:${c.company}`   : '',
    c.mobile   ? `TEL;TYPE=CELL:${c.mobile}`      : '',
    c.email    ? `EMAIL;TYPE=WORK:${c.email}`      : '',
    c.website  ? `URL:${c.website}`                : '',
    c.linkedin ? `X-SOCIALPROFILE;type=linkedin:${c.linkedin}` : '',
    photoData  ? foldLine(`PHOTO;ENCODING=b;TYPE=JPEG:${photoData}`) : '',
    'END:VCARD'
  ].filter(Boolean).join('\r\n');

  return lines;
}

  document.getElementById('addContactBtn').addEventListener('click', function(e) {
    e.preventDefault();
    const blob = new Blob([buildVCard(contact)], { type: 'text/vcard;charset=utf-8' });
    const url  = URL.createObjectURL(blob);
    const a    = document.createElement('a');
    a.href = url; a.download = `${contact.firstName}_${contact.lastName}.vcf`;
    document.body.appendChild(a); a.click();
    document.body.removeChild(a); URL.revokeObjectURL(url);
  });
</script>
