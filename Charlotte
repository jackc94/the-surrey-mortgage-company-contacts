<style>
  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

  :root {
    --sage:       #dae3df;
    --sage-mid:   #b8cdc6;
    --sage-dark:  #6e9189;
    --sage-deep:  #3d6b61;
    --white:      #ffffff;
    --off-white:  #f7faf9;
    --ink:        #2c2c2c;
    --muted:      #7a8c8a;
    --border:     #ccddd8;
  }

  html, body {
  min-height: 100vh;
  }

  body {
    min-height: 100vh;
    background-attachment: fixed;
    background: var(--sage);
    background-image:
      radial-gradient(ellipse at 30% 0%, rgba(255,255,255,0.45) 0%, transparent 55%),
      radial-gradient(ellipse at 80% 100%, rgba(61,107,97,0.12) 0%, transparent 50%);
    display: flex;
    justify-content: center; /* horizontal */
    align-items: flex-start; /* top */
    font-family: 'Raleway', sans-serif;
    padding: 2rem 1.25rem;
  }

  .wrapper {
    width: 100%;
    max-width: 440px;
    animation: rise 0.65s cubic-bezier(0.16,1,0.3,1) both;
  }

  @keyframes rise {
    from { opacity: 0; transform: translateY(20px); }
    to   { opacity: 1; transform: translateY(0); }
  }

  .card-header {
    background: #ffffff;
    padding: 1.75rem 2rem 1.25rem;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.6rem;
    position: relative;
    border: 1px solid var(--border);
    border-bottom: none;
  }

  .card-header::after {
    content: '';
    position: absolute;
    bottom: 0; left: 0; right: 0;
    height: 3px;
    background: linear-gradient(90deg, var(--sage-mid), var(--sage-deep), var(--sage-mid));
  }

  .header-logo {
    width: 200px;
    height: auto;
    display: block;
  }

  .brand-tagline {
    font-size: 0.4rem;
    color: var(--ink);
    letter-spacing: 0.18em;
    text-transform: uppercase;
    font-weight: 400;
    padding-bottom: 0.4rem;
  }

  .card-body {
    background: var(--white);
    padding: 2rem 2rem 1.75rem;
    border: 1px solid var(--border);
    border-top: none;
  }

  .profile {
    display: flex;
    align-items: center;
    gap: 1.1rem;
    margin-bottom: 1.5rem;
    padding-bottom: 1.5rem;
    border-bottom: 1px solid var(--border);
  }

  .avatar {
    width: 68px; height: 68px;
    border-radius: 50%;
    background: linear-gradient(135deg, var(--sage-dark) 0%, var(--sage-deep) 100%);
    display: flex;
    align-items: center;
    justify-content: center;
    font-family: 'Playfair Display', serif;
    font-size: 1.5rem;
    color: #fff;
    flex-shrink: 0;
    box-shadow: 0 2px 12px rgba(61,107,97,0.25);
    overflow: hidden;
  }

  .avatar img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center top;
  }

  .advisor-name {
    font-family: 'Playfair Display', serif;
    font-size: 1.25rem;
    font-weight: 400;
    color: var(--ink);
    line-height: 1.2;
  }

  .advisor-title {
    font-size: 0.72rem;
    color: var(--sage-dark);
    font-weight: 400;
    letter-spacing: 0.03em;
    margin-top: 0.3rem;
    line-height: 1.5;
  }

  .details {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 0.7rem;
    margin-bottom: 1.6rem;
  }

  .detail-item {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    animation: rise 0.5s cubic-bezier(0.16,1,0.3,1) both;
  }

  .detail-item:nth-child(1) { animation-delay: 0.08s; }
  .detail-item:nth-child(2) { animation-delay: 0.12s; }
  .detail-item:nth-child(3) { animation-delay: 0.16s; }
  .detail-item:nth-child(4) { animation-delay: 0.20s; }
  .detail-item:nth-child(5) { animation-delay: 0.24s; }

  .detail-icon {
    width: 34px; height: 34px;
    background: var(--off-white);
    border: 1px solid var(--border);
    border-radius: 8px;
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
    color: var(--sage-dark);
  }

  .detail-icon svg {
    width: 15px; height: 15px;
    stroke: currentColor;
    fill: none;
    stroke-width: 1.6;
    stroke-linecap: round;
    stroke-linejoin: round;
  }

  .detail-label {
    display: block;
    font-size: 0.59rem;
    color: var(--muted);
    text-transform: uppercase;
    letter-spacing: 0.14em;
    font-weight: 700;
    margin-bottom: 0.1rem;
  }

  .detail-value {
    font-size: 0.83rem;
    color: var(--ink);
    font-weight: 400;
    line-height: 1.4;
  }

  .detail-value a {
    color: var(--ink);
    text-decoration: none;
    transition: color 0.2s;
  }

  .detail-value a:hover { color: var(--sage-deep); }

  .btn-add {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0.55rem;
    width: 100%;
    padding: 0.85rem 1.5rem;
    background: var(--sage-deep);
    color: #fff;
    border: none;
    cursor: pointer;
    font-family: 'Lato', sans-serif;
    font-size: 0.78rem;
    font-weight: 700;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    text-decoration: none;
    transition: background 0.25s ease, transform 0.15s ease;
    border-radius: 2px;
  }

  .btn-add:hover { background: #2e5148; }
  .btn-add:active { transform: scale(0.99); }

  .btn-add svg {
    width: 16px; height: 16px;
    stroke: currentColor;
    fill: none;
    stroke-width: 1.8;
    stroke-linecap: round;
    stroke-linejoin: round;
    flex-shrink: 0;
  }

  .card-footer {
    background: var(--off-white);
    border: 1px solid var(--border);
    border-top: none;
    padding: 0.85rem 2rem;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0.4rem;
  }

  .card-footer span {
    font-size: 0.6rem;
    color: var(--muted);
    letter-spacing: 0.06em;
  }

  .card-footer a {
    font-size: 0.6rem;
    color: var(--sage-dark);
    text-decoration: none;
  }

  .card-footer a:hover { text-decoration: underline; }

  .disclaimer {
    margin-top: 1.1rem;
    font-size: 0.58rem;
    color: rgba(44,44,44,0.5);
    text-align: center;
    line-height: 1.6;
    letter-spacing: 0.01em;
    max-width: 400px;
    margin-left: auto;
    margin-right: auto;
  }
</style>
